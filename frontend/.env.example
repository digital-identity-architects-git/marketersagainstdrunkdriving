# Optional: absolute base URL for the backend API.
#
# Leave this blank to use same-origin relative /api requests. That requires a
# reverse proxy (e.g. the .htaccess shipped in frontend/public) that forwards
# /api to the Node backend on the same domain.
#
# Set it to an absolute URL when the API lives on a different origin, such as a
# SiteGround Node app on an API subdomain. CORS is already enabled on the
# backend, so cross-origin requests work out of the box.
#   VITE_API_BASE_URL=https://api.marketersagainstdrunkdriving.com
VITE_API_BASE_URL=
